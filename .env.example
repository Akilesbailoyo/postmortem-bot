# Slack (production bot + demo:real)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# GitHub (PR enrichment)
GITHUB_TOKEN=ghp_your_pat

# OpsGenie (alerts in incident window)
OPSGENIE_API_KEY=your-opsgenie-api-key
# Optional: EU region uses https://api.eu.opsgenie.com
OPSGENIE_BASE_URL=https://api.opsgenie.com

# Anthropic (live draft in demo:mock or production)
ANTHROPIC_API_KEY=sk-ant-api03-...
# Default matches spec; override if your account uses a different model id
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# demo:mock (default) | demo:real uses real fetchers when keys present
MODE=mock
